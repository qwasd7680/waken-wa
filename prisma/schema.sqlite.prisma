generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String
  token      String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")

  @@map("api_tokens")
}

model ActivityLog {
  id           Int       @id @default(autoincrement())
  device       String
  processName  String    @map("process_name")
  processTitle String?   @map("process_title")
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("activity_logs")
}

model SiteConfig {
  id            Int      @id @default(1)
  userName      String   @map("user_name")
  userBio       String   @map("user_bio")
  avatarUrl     String   @map("avatar_url")
  userNote      String   @map("user_note")
  historyWindowMinutes Int @map("history_window_minutes") @default(120)
  historyWindowHintText String @map("history_window_hint_text") @default("历史窗口：最近 2 小时（可在设置中调整）")
  appMessageRules Json?  @map("app_message_rules")
  pageLockEnabled Boolean @map("page_lock_enabled") @default(false)
  pageLockPasswordHash String? @map("page_lock_password_hash")
  currentlyText String   @map("currently_text") @default("currently")
  earlierText   String   @map("earlier_text") @default("earlier")
  updatesText   String   @map("updates_text") @default("updates every 30 seconds")
  adminText     String   @map("admin_text") @default("admin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}
