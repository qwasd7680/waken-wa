// Default: SQLite (local dev). Env: DATABASE_URL="file:./prisma/dev.db"
// For PostgreSQL use prisma/schema.postgres.prisma; URL: DATABASE_URL or POSTGRES_URL (postgres:// or postgresql://).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String
  /// Stored as `h$` + SHA-256 hex of the secret; legacy rows may hold plaintext until first successful auth.
  token      String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  devices    Device[]

  @@map("api_tokens")
}

model ActivityLog {
  id                    Int       @id @default(autoincrement())
  device                String
  generatedHashKey      String    @map("generated_hash_key")
  deviceId              Int?      @map("device_id")
  processName           String    @map("process_name")
  processTitle          String?   @map("process_title")
  startedAt             DateTime  @default(now()) @map("started_at")
  endedAt               DateTime? @map("ended_at")
  metadata              Json?
  reportIntervalSeconds Int?      @map("report_interval_seconds")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  deviceRef             Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model Device {
  id               Int           @id @default(autoincrement())
  displayName      String        @map("display_name")
  generatedHashKey String        @unique @map("generated_hash_key")
  status           String        @default("active")
  apiTokenId       Int?          @map("api_token_id")
  lastSeenAt       DateTime?     @map("last_seen_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  apiToken         ApiToken?     @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  activityLogs     ActivityLog[]

  @@map("devices")
}

model SiteConfig {
  id                   Int      @id @default(1)
  pageTitle            String   @map("page_title") @default("别睡了啦！看看你在做什么")
  userName             String   @map("user_name")
  userBio              String   @map("user_bio")
  avatarUrl            String   @map("avatar_url")
  userNote             String   @map("user_note")
  userNoteHitokotoEnabled   Boolean  @map("user_note_hitokoto_enabled") @default(false)
  userNoteHitokotoCategories Json?   @map("user_note_hitokoto_categories")
  userNoteHitokotoEncode    String   @map("user_note_hitokoto_encode") @default("json")
  themePreset          String   @map("theme_preset") @default("basic")
  themeCustomSurface   Json?    @map("theme_custom_surface")
  customCss            String?  @map("custom_css")
  historyWindowMinutes Int      @map("history_window_minutes") @default(120)
  appMessageRules      Json?    @map("app_message_rules")
  /// When a rule matches: append ` | processName` to status line (default on).
  appMessageRulesShowProcessName Boolean @map("app_message_rules_show_process_name") @default(true)
  appBlacklist         Json?    @map("app_blacklist")
  appWhitelist         Json?    @map("app_whitelist")
  appFilterMode        String   @map("app_filter_mode") @default("blacklist")
  appNameOnlyList      Json?    @map("app_name_only_list")
  processStaleSeconds  Int      @map("process_stale_seconds") @default(500)
  pageLockEnabled      Boolean  @map("page_lock_enabled") @default(false)
  pageLockPasswordHash String?  @map("page_lock_password_hash")
  currentlyText        String   @map("currently_text") @default("当前状态")
  earlierText          String   @map("earlier_text") @default("最近的随想录")
  adminText            String   @map("admin_text") @default("admin")
  autoAcceptNewDevices Boolean  @map("auto_accept_new_devices") @default(false)
  /// null = any device with a valid Bearer token may use inspiration APIs; non-null array = only these `Device.generatedHashKey` values (must match token-bound device).
  inspirationAllowedDeviceHashes Json? @map("inspiration_allowed_device_hashes")
  scheduleSlotMinutes       Int      @map("schedule_slot_minutes") @default(30)
  /// Per-weekday admin timetable axis: range, tick interval, fixed vs free grid. Null = derive from scheduleSlotMinutes.
  scheduleGridByWeekday     Json?    @map("schedule_grid_by_weekday")
  scheduleCourses           Json?    @map("schedule_courses")
  scheduleIcs               String?  @map("schedule_ics")
  scheduleInClassOnHome     Boolean  @map("schedule_in_class_on_home") @default(false)
  scheduleHomeShowLocation  Boolean  @map("schedule_home_show_location") @default(false)
  scheduleHomeShowTeacher   Boolean  @map("schedule_home_show_teacher") @default(false)
  /** When true, home schedule card shows the next class preview between sessions (「下一节」). */
  scheduleHomeShowNextUpcoming Boolean @map("schedule_home_show_next_upcoming") @default(false)
  /** Home schedule card left label when all of today’s sessions have ended. */
  scheduleHomeAfterClassesLabel String @map("schedule_home_after_classes_label") @default("正在摸鱼")
  /// Whole-page mouse parallax tilt (GlobalMouseTilt in root layout). Default off.
  globalMouseTiltEnabled Boolean @map("global_mouse_tilt_enabled") @default(false)
  hcaptchaEnabled      Boolean  @map("hcaptcha_enabled") @default(false)
  hcaptchaSiteKey      String?  @map("hcaptcha_site_key")
  hcaptchaSecretKey    String?  @map("hcaptcha_secret_key")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model SystemSecret {
  key   String @id
  value String

  @@map("system_secrets")
}

model InspirationEntry {
  id Int @id @default(autoincrement())

  title   String? @map("title")
  content String  @map("content")

  imageDataUrl String? @map("image_data_url")
  statusSnapshot String? @map("status_snapshot")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bodyAssets InspirationAsset[]

  @@map("inspiration_entries")
}

/// Inline images referenced from inspiration markdown (`/api/inspiration/img/<publicKey>`).
model InspirationAsset {
  id Int @id @default(autoincrement())

  publicKey    String  @unique @default(uuid()) @map("public_key")
  imageDataUrl String  @map("image_data_url")

  inspirationEntryId Int?              @map("inspiration_entry_id")
  inspirationEntry   InspirationEntry? @relation(fields: [inspirationEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("inspiration_assets")
}
