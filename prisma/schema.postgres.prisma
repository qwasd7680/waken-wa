// PostgreSQL schema (Vercel / Supabase / self-hosted Postgres).
// Use: prisma generate --schema prisma/schema.postgres.prisma
// Env: POSTGRES_PRISMA_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(200)
  token      String    @unique @db.VarChar(64)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  devices    Device[]

  @@map("api_tokens")
}

model ActivityLog {
  id                    Int       @id @default(autoincrement())
  device                String    @db.VarChar(200)
  generatedHashKey      String    @map("generated_hash_key") @db.VarChar(128)
  deviceId              Int?      @map("device_id")
  processName           String    @map("process_name") @db.VarChar(200)
  processTitle          String?   @map("process_title")
  startedAt             DateTime  @default(now()) @map("started_at")
  endedAt               DateTime? @map("ended_at")
  metadata              Json?
  reportIntervalSeconds Int?      @map("report_interval_seconds")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  deviceRef             Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}

model Device {
  id               Int           @id @default(autoincrement())
  displayName      String        @map("display_name") @db.VarChar(200)
  generatedHashKey String        @unique @map("generated_hash_key") @db.VarChar(128)
  status           String        @default("active") @db.VarChar(20)
  apiTokenId       Int?          @map("api_token_id")
  lastSeenAt       DateTime?     @map("last_seen_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  apiToken         ApiToken?     @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  activityLogs     ActivityLog[]

  @@map("devices")
}

model SiteConfig {
  id                   Int      @id @default(1)
  pageTitle            String   @map("page_title") @db.VarChar(120) @default("别睡了啦！看看你在做什么")
  userName             String   @map("user_name") @db.VarChar(120)
  userBio              String   @map("user_bio")
  avatarUrl            String   @map("avatar_url")
  userNote             String   @map("user_note")
  themePreset          String   @map("theme_preset") @default("basic") @db.VarChar(50)
  themeCustomSurface   Json?    @map("theme_custom_surface")
  customCss            String?  @map("custom_css")
  historyWindowMinutes Int      @map("history_window_minutes") @default(120)
  appMessageRules      Json?    @map("app_message_rules")
  appBlacklist         Json?    @map("app_blacklist")
  appWhitelist         Json?    @map("app_whitelist")
  appFilterMode        String   @map("app_filter_mode") @default("blacklist") @db.VarChar(20)
  appNameOnlyList      Json?    @map("app_name_only_list")
  processStaleSeconds  Int      @map("process_stale_seconds") @default(500)
  pageLockEnabled      Boolean  @map("page_lock_enabled") @default(false)
  pageLockPasswordHash String?  @map("page_lock_password_hash")
  currentlyText        String   @map("currently_text") @db.VarChar(60) @default("当前状态")
  earlierText          String   @map("earlier_text") @db.VarChar(60) @default("最近的随想录")
  adminText            String   @map("admin_text") @db.VarChar(30) @default("admin")
  autoAcceptNewDevices Boolean  @map("auto_accept_new_devices") @default(false)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model InspirationEntry {
  id Int @id @default(autoincrement())

  title   String? @map("title") @db.VarChar(200)
  content String  @map("content") @db.Text

  imageDataUrl String? @map("image_data_url") @db.Text
  statusSnapshot String? @map("status_snapshot") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bodyAssets InspirationAsset[]

  @@map("inspiration_entries")
}

model InspirationAsset {
  id Int @id @default(autoincrement())

  publicKey    String  @unique @default(uuid()) @map("public_key") @db.Uuid
  imageDataUrl String  @map("image_data_url") @db.Text

  inspirationEntryId Int?              @map("inspiration_entry_id")
  inspirationEntry   InspirationEntry? @relation(fields: [inspirationEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("inspiration_assets")
}
