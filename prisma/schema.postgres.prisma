// Use: prisma generate --schema prisma/schema.postgres.prisma
// Env: standard postgres URL in DATABASE_URL or POSTGRES_URL (see lib/db-env.ts).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(200)
  /// `h$` + SHA-256 hex (66 chars); legacy plaintext up to 64 hex.
  token      String    @unique @db.VarChar(128)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  devices    Device[]

  @@map("api_tokens")
}

model Device {
  id               Int           @id @default(autoincrement())
  displayName      String        @map("display_name") @db.VarChar(200)
  generatedHashKey String        @unique @map("generated_hash_key") @db.VarChar(128)
  showSteamNowPlaying Boolean   @default(false) @map("show_steam_now_playing")
  status           String        @default("active") @db.VarChar(20)
  apiTokenId       Int?          @map("api_token_id")
  lastSeenAt       DateTime?     @map("last_seen_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @default(now()) @updatedAt @map("updated_at")
  apiToken         ApiToken?     @relation(fields: [apiTokenId], references: [id], onDelete: SetNull)
  userActivities   UserActivity[]

  @@map("devices")
}

model UserActivity {
  id               Int      @id @default(autoincrement())
  deviceId         Int      @map("device_id")
  generatedHashKey String   @map("generated_hash_key") @db.VarChar(128)
  processName      String   @map("process_name") @db.VarChar(200)
  processTitle     String?  @map("process_title") @db.Text
  metadata         Json?
  startedAt        DateTime @default(now()) @map("started_at")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  device           Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, processName])
  @@map("user_activities")
}

model SiteConfig {
  id                   Int      @id @default(1)
  pageTitle            String   @map("page_title") @db.VarChar(120) @default("别睡了啦！看看你在做什么")
  userName             String   @map("user_name") @db.VarChar(120)
  userBio              String   @map("user_bio")
  avatarUrl            String   @map("avatar_url")
  userNote             String   @map("user_note")
  userNoteHitokotoEnabled    Boolean  @map("user_note_hitokoto_enabled") @default(false)
  userNoteHitokotoCategories Json?    @map("user_note_hitokoto_categories")
  userNoteHitokotoEncode     String   @map("user_note_hitokoto_encode") @default("json") @db.VarChar(10)
  themePreset          String   @map("theme_preset") @default("basic") @db.VarChar(50)
  themeCustomSurface   Json?    @map("theme_custom_surface")
  customCss            String?  @map("custom_css")
  historyWindowMinutes Int      @map("history_window_minutes") @default(120)
  appMessageRules      Json?    @map("app_message_rules")
  appMessageRulesShowProcessName Boolean @map("app_message_rules_show_process_name") @default(true)
  appBlacklist         Json?    @map("app_blacklist")
  appWhitelist         Json?    @map("app_whitelist")
  appFilterMode        String   @map("app_filter_mode") @default("blacklist") @db.VarChar(20)
  appNameOnlyList      Json?    @map("app_name_only_list")
  processStaleSeconds  Int      @map("process_stale_seconds") @default(500)
  pageLockEnabled      Boolean  @map("page_lock_enabled") @default(false)
  pageLockPasswordHash String?  @map("page_lock_password_hash")
  currentlyText        String   @map("currently_text") @db.VarChar(60) @default("当前状态")
  earlierText          String   @map("earlier_text") @db.VarChar(60) @default("最近的随想录")
  adminText            String   @map("admin_text") @db.VarChar(30) @default("admin")
  autoAcceptNewDevices Boolean  @map("auto_accept_new_devices") @default(false)
  /// null = any device with a valid Bearer token may use inspiration APIs; non-null array = only these `Device.generatedHashKey` values (must match token-bound device).
  inspirationAllowedDeviceHashes Json? @map("inspiration_allowed_device_hashes")
  scheduleSlotMinutes       Int      @map("schedule_slot_minutes") @default(30)
  schedulePeriodTemplate    Json?    @map("schedule_period_template")
  scheduleGridByWeekday     Json?    @map("schedule_grid_by_weekday")
  scheduleCourses           Json?    @map("schedule_courses")
  scheduleIcs               String?  @map("schedule_ics")
  scheduleInClassOnHome     Boolean  @map("schedule_in_class_on_home") @default(false)
  scheduleHomeShowLocation  Boolean  @map("schedule_home_show_location") @default(false)
  scheduleHomeShowTeacher   Boolean  @map("schedule_home_show_teacher") @default(false)
  scheduleHomeShowNextUpcoming Boolean @map("schedule_home_show_next_upcoming") @default(false)
  scheduleHomeAfterClassesLabel String @map("schedule_home_after_classes_label") @db.VarChar(40) @default("正在摸鱼")
  globalMouseTiltEnabled Boolean @map("global_mouse_tilt_enabled") @default(false)
  /// When true, homepage activity cards do not show now-playing media (title / artist).
  hideActivityMedia    Boolean  @map("hide_activity_media") @default(false)
  hcaptchaEnabled      Boolean  @map("hcaptcha_enabled") @default(false)
  hcaptchaSiteKey      String?  @map("hcaptcha_site_key") @db.VarChar(200)
  hcaptchaSecretKey    String?  @map("hcaptcha_secret_key") @db.VarChar(200)
  /// Display timezone for timestamps (e.g. "Asia/Shanghai", "UTC"). Default: Asia/Shanghai (GMT+8).
  displayTimezone      String   @map("display_timezone") @db.VarChar(50) @default("Asia/Shanghai")
  /// Activity update mode: "sse" (Server-Sent Events) or "polling" (HTTP polling)
  activityUpdateMode   String   @map("activity_update_mode") @db.VarChar(20) @default("sse")
  /// Steam integration: enable Steam status display on homepage.
  steamEnabled         Boolean  @map("steam_enabled") @default(false)
  /// Steam 64-bit ID (e.g. "76561198000000000").
  steamId              String?  @map("steam_id") @db.VarChar(30)
  /// Steam Web API key. Optional fallback: env STEAM_API_KEY.
  steamApiKey          String?  @map("steam_api_key") @db.VarChar(128)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model SystemSecret {
  key   String @id @db.VarChar(64)
  value String @db.VarChar(512)

  @@map("system_secrets")
}

model InspirationEntry {
  id Int @id @default(autoincrement())

  title   String? @map("title") @db.VarChar(200)
  content String  @map("content") @db.Text

  imageDataUrl String? @map("image_data_url") @db.Text
  statusSnapshot String? @map("status_snapshot") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bodyAssets InspirationAsset[]

  @@map("inspiration_entries")
}

model InspirationAsset {
  id Int @id @default(autoincrement())

  publicKey    String  @unique @default(uuid()) @map("public_key") @db.Uuid
  imageDataUrl String  @map("image_data_url") @db.Text

  inspirationEntryId Int?              @map("inspiration_entry_id")
  inspirationEntry   InspirationEntry? @relation(fields: [inspirationEntryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("inspiration_assets")
}
