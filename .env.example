JWT_SECRET=

# --- hCaptcha (optional, overrides DB settings when both are set) ---
# HCAPTCHA_SITE_KEY=
# HCAPTCHA_SECRET_KEY=

# --- SQLite (default schema: prisma/schema.prisma) ---
DATABASE_URL="file:./prisma/dev.db"

# --- PostgreSQL (prisma/schema.postgres.prisma + pnpm db:generate:postgres / db:init) ---
# Standard URL: postgresql://... or postgres://...
# App / build / generate / push: POSTGRES_PRISMA_URL > DATABASE_URL > POSTGRES_URL
# pnpm db:init (postinstall): POSTGRES_URL_NON_POOLING > POSTGRES_PRISMA_URL > DATABASE_URL > POSTGRES_URL
# POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Optional explicit flag when no postgres-looking URL is detected yet:
# DATABASE_PROVIDER=postgresql
