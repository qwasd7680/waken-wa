JWT_SECRET=

# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# --- SQLite (default schema: prisma/schema.prisma) ---
DATABASE_URL="file:./prisma/dev.db"



# --- Docker Compose (docker-compose.yml; same directory as compose file) ---
# POSTGRES_PASSWORD=change-me
# POSTGRES_USER=waken
# POSTGRES_DB=waken
# APP_PORT=3000
# JWT_SECRET=...
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
# (Compose sets DATABASE_URL for the app service; do not use file: SQLite URL there.)

# --- PostgreSQL TLS (Prisma driver adapter / node-pg) ---
# If you see P1011 / "self-signed certificate in certificate chain", either install the CA
# your provider documents, or (dev / trusted networks only) relax verification:
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false
# Equivalent: POSTGRES_SSL_INSECURE=true
